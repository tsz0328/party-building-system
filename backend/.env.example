# 服务端环境变量 - 开发环境
# 复制此文件为 .env 并填写实际值，不要提交 .env 到 git

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=party_building
DB_USER=root
DB_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173
